# ===== R3D Bot — Environment Variables =====
# انسخ هذا الملف وسمّيه .env واملأ القيم

# ─── مطلوب ───
BOT_TOKEN=          # توكن البوت من @BotFather
OWNER_ID=           # معرّفك الرقمي (من @userinfobot)
BOT_USERNAME=       # اسم البوت بدون @

# ─── API Telegram (من my.telegram.org) ───
API_ID=             # الرقم الذي تحصل عليه من my.telegram.org
API_HASH=           # الهاش الذي تحصل عليه من my.telegram.org

# ─── للتشغيل السحابي (Replit/Railway/Render) ───
# REDIS_URL=rediss://default:PASSWORD@host:6379
# (اتركه فارغاً إذا كنت تشغّل على سيرفرك الخاص مع Redis محلي)

# ─── اختياري ───
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
